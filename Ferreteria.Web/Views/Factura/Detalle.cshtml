@model Ferreteria.Application.DTOs.Facturacion.VistaFacturaDto
@{
    ViewData["Title"] = "Detalle de " + Model.NumeroFactura;
}

<div class="card" style="max-width: 900px; margin: 0 auto; padding: 2rem;">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
        <div>
            <h2 style="margin-bottom: 0.2rem; color: var(--brand-primary);">Factura Comercial</h2>
            <div style="font-family: monospace; font-size: 1.2rem; font-weight: 600;">@Model.NumeroFactura</div>
            
            @if(Model.Estado == "Anulada")
            {
                <span class="badge badge-inactive" style="font-size: 1rem; margin-top: 0.5rem;"><i class="fa-solid fa-ban"></i> FACTURA ANULADA</span>
            }
        </div>
        <div style="text-align: right;">
            <div style="font-size: 0.9rem; color: var(--text-secondary);">Fecha de Emisión</div>
            <div style="font-weight: 500;">@Model.FechaEmision.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</div>
            <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.5rem;">Cajero / Vendedor</div>
            <div style="font-weight: 500;">@Model.VendedorNombre</div>
        </div>
    </div>

    <div style="background: #f8fafc; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--border-color);">
        <h4 style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.9rem; text-transform: uppercase;">Facturado A:</h4>
        <div style="font-size: 1.2rem; font-weight: 700;">@Model.ClienteNombre</div>
        <div style="color: var(--text-secondary); margin-top: 0.2rem;">Doc./RNC: @Model.ClienteIdentificacion</div>
        <div style="margin-top: 0.5rem; font-size: 0.9rem; font-weight: 600;"><i class="fa-solid fa-money-bill-wave"></i> Método de Pago: @Model.MetodoPago</div>
    </div>

    <table style="width: 100%; margin-bottom: 2rem; border: 1px solid var(--border-color);">
        <thead style="background: #e2e8f0;">
            <tr>
                <th style="padding: 0.75rem; text-align: left;">CÓDIGO</th>
                <th style="padding: 0.75rem; text-align: left;">DESCRIPCIÓN</th>
                <th style="padding: 0.75rem; text-align: right;">CANT.</th>
                <th style="padding: 0.75rem; text-align: right;">PRECIO UD.</th>
                <th style="padding: 0.75rem; text-align: right;">ITBIS</th>
                <th style="padding: 0.75rem; text-align: right;">TOTAL</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Detalles)
            {
                <tr style="border-bottom: 1px solid #f1f5f9;">
                    <td style="padding: 0.75rem; font-family: monospace; font-size: 0.85rem;">@d.ProductoSku</td>
                    <td style="padding: 0.75rem; font-weight: 500;">@d.ProductoNombre</td>
                    <td style="padding: 0.75rem; text-align: right;">@d.Cantidad</td>
                    <td style="padding: 0.75rem; text-align: right;">@d.PrecioUnitario.ToString("C2")</td>
                    <td style="padding: 0.75rem; text-align: right; color: var(--text-secondary);">@d.ImpuestoMonto.ToString("C2")</td>
                    <td style="padding: 0.75rem; text-align: right; font-weight: 600;">@d.TotalNeto.ToString("C2")</td>
                </tr>
            }
        </tbody>
    </table>

    <div style="display: flex; justify-content: flex-end;">
        <div style="width: 300px; background: #f8fafc; padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                <span style="color: var(--text-secondary);">Subtotal:</span>
                <span style="font-weight: 600;">@Model.Subtotal.ToString("C2")</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                <span style="color: var(--text-secondary);">Descuentos:</span>
                <span style="font-weight: 600; color: var(--brand-danger);">- @Model.DescuentoTotal.ToString("C2")</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
                <span style="color: var(--text-secondary);">ITBIS (18%):</span>
                <span style="font-weight: 600;">@Model.ImpuestosTotal.ToString("C2")</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-top: 1rem;">
                <span style="font-size: 1.2rem; font-weight: 700;">TOTAL RD$:</span>
                <span style="font-size: 1.2rem; font-weight: 800; color: var(--brand-primary);">@Model.TotalGeneral.ToString("N2")</span>
            </div>
        </div>
    </div>

    <hr style="border:0; border-top: 1px solid var(--border-color); margin: 2rem 0;" />
    
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <a asp-action="Index" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Volver a Ventas</a>
        
        <div style="display: flex; gap: 0.5rem;">
            <button type="button" class="btn btn-primary" onclick="window.print();"><i class="fa-solid fa-print"></i> Imprimir</button>
            @if(Model.Estado == "Completada")
            {
                <form asp-action="Anular" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('¿Está SEGURO que desea ANULAR esta factura? Los productos regresarán al inventario.');" style="margin:0;">
                    <button type="submit" class="btn btn-danger"><i class="fa-solid fa-ban"></i> Anular Factura</button>
                </form>
            }
        </div>
    </div>
</div>

<style>
    @@media print {
        body * { visibility: hidden; }
        .card, .card * { visibility: visible; }
        .card { position: absolute; left: 0; top: 0; width: 100%; border: none; box-shadow: none; }
        .btn, .sidebar, .topvar { display: none !important; }
    }
</style>
