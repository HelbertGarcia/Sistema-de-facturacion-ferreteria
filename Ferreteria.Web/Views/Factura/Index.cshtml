@model IEnumerable<Ferreteria.Application.DTOs.Facturacion.VistaFacturaDto>
@{
    ViewData["Title"] = "Historial de Facturación";
}

<div class="card">
    <div class="title-header">
        <h3><i class="fa-solid fa-file-invoice-dollar"></i> Ventas & Facturas</h3>
        <a asp-action="Pos" class="btn btn-primary"><i class="fa-solid fa-cash-register"></i> Punto de Venta (POS)</a>
    </div>

    <div style="margin-bottom: 1.5rem;">
        <form asp-action="Index" method="get" style="display: flex; gap: 0.5rem; max-width: 500px;">
            <input type="text" name="search" class="form-control" placeholder="Buscar Nro. Factura o Cliente..." value="@ViewData["Search"]" />
            <button type="submit" class="btn btn-outline"><i class="fa-solid fa-magnifying-glass"></i> Buscar</button>
        </form>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Nro. Factura</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Vendedor</th>
                    <th style="text-align: right;">Monto Total</th>
                    <th>Estado</th>
                    <th style="text-align: center;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td style="font-family: monospace; font-weight: 600;">@f.NumeroFactura</td>
                        <td style="font-size: 0.85rem; color: var(--text-secondary);">@f.FechaEmision.ToLocalTime().ToString("dd/MMM/yyyy HH:mm")</td>
                        <td>
                            <div style="font-weight: 500;">@f.ClienteNombre</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">@f.ClienteIdentificacion</div>
                        </td>
                        <td style="font-size: 0.85rem;">@f.VendedorNombre</td>
                        <td style="text-align: right; font-weight: 700; color: var(--brand-primary);">@f.TotalGeneral.ToString("C2")</td>
                        <td>
                            @if(f.Estado == "Completada")
                            {
                                <span class="badge badge-active">Completada</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Anulada</span>
                            }
                        </td>
                        <td style="text-align: center;">
                            <a asp-action="Detalle" asp-route-id="@f.Id" class="btn btn-outline" style="padding: 0.4rem 0.6rem;" title="Ver Detalle"><i class="fa-solid fa-eye"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if(!Model.Any()) {
            <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
                <i class="fa-solid fa-receipt" style="font-size: 3rem; opacity: 0.2; margin-bottom: 1rem;"></i>
                <p>No se encontraron facturas.</p>
            </div>
        }
    </div>
</div>
