@{
    ViewData["Title"] = "Dashboard de Inicio";
}

<div class="card" style="margin-bottom: 2rem;">
    <h3>Bienvenido, @User.Identity.Name!</h3>
    <p style="color: var(--text-secondary);">Has ingresado al sistema de punto de venta y gestión de inventario de La Ferretería.</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
    <div class="card" style="border-top: 4px solid var(--brand-primary);">
        <h4 style="color: var(--text-secondary); margin-bottom: 0.5rem; font-size: 1rem;">Ventas de Hoy</h4>
        <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;">
            RD$ 0.00
        </div>
        <a asp-controller="Factura" asp-action="Index" style="font-size: 0.85rem; font-weight: 500;">Ver facturas &rarr;</a>
    </div>

    <div class="card" style="border-top: 4px solid var(--brand-success);">
        <h4 style="color: var(--text-secondary); margin-bottom: 0.5rem; font-size: 1rem;">Clientes Nuevos</h4>
        <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;">
            0
        </div>
        <a asp-controller="Cliente" asp-action="Index" style="font-size: 0.85rem; font-weight: 500;">Ver clientes &rarr;</a>
    </div>

    <div class="card" style="border-top: 4px solid var(--brand-danger);">
        <h4 style="color: var(--text-secondary); margin-bottom: 0.5rem; font-size: 1rem;">Alertas de Stock</h4>
        <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;">
            0
        </div>
        <a asp-controller="Inventario" asp-action="Index" style="font-size: 0.85rem; font-weight: 500;">Ver inventario bajo &rarr;</a>
    </div>
</div>
