@model Ferreteria.Application.DTOs.Inventario.MovimientoDto
@{
    ViewData["Title"] = "Registrar Entrada de Mercancía";
}

<div class="card" style="max-width: 700px; margin: 0 auto; border-top: 4px solid var(--brand-success);">
    <div class="title-header">
        <h3><i class="fa-solid fa-truck-loading"></i> @ViewData["Title"]</h3>
        <a asp-action="Index" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Registro</a>
    </div>

    <form asp-action="Entrada" method="post">
        
        @if (!ViewData.ModelState.IsValid)
        {
            <div style="padding: 1rem; background: rgba(239,68,68,0.1); color: var(--brand-danger); border-radius: 8px; margin-bottom: 1.5rem;">
                <div asp-validation-summary="All" style="margin:0;"></div>
            </div>
        }

        <div class="form-group">
            <label class="form-label">Producto a Ingresar</label>
            <select asp-for="ProductoId" asp-items="@ViewBag.ProductosList" class="form-control" autofocus>
                <option value="">-- Busque o Seleccione un Producto --</option>
            </select>
            <span asp-validation-for="ProductoId" class="form-error"></span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group">
                <label class="form-label">Cantidad (Unidades/Medida)</label>
                <input asp-for="Cantidad" class="form-control" type="number" min="1" step="1" />
                <span asp-validation-for="Cantidad" class="form-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Nuevo Costo Unitario (RD$)</label>
                <input asp-for="CostoUnitario" class="form-control" type="number" min="0.01" step="0.01" />
                <span asp-validation-for="CostoUnitario" class="form-error"></span>
                <small style="color: var(--text-muted); font-size: 0.8rem; display:block; margin-top:4px;">*Actualizará el precio de venta si varía el costo.</small>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Proveedor o NCF / Referencia Factura</label>
            <input asp-for="ProveedorOReferencia" class="form-control" autocomplete="off" placeholder="Ej. Factura B0100000142 del Proveedor X" />
        </div>

        <hr style="border:0; border-top: 1px solid var(--border-color); margin: 2rem 0;" />
        
        <div style="text-align: right;">
            <button type="submit" class="btn btn-success" style="padding: 0.8rem 2rem; font-size: 1.1rem;"><i class="fa-solid fa-check"></i> Adicionar al Inventario</button>
        </div>
    </form>
</div>
